# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env (berisi rahasia).
# Ambil dari Supabase Dashboard -> Project Settings -> API.

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Gunakan kunci yang sesuai kebutuhan. Untuk akses penuh dari backend = service_role,
# TAPI jaga kerahasiaannya (jangan pernah masuk ke git / frontend).
SUPABASE_KEY=your-supabase-key-here
